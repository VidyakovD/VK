# =============================================================================
# VK SaaS for Entrepreneurs — Environment Variables
# Copy to .env and fill in real values. .env MUST be in .gitignore.
# =============================================================================

# --- Application -------------------------------------------------------------
ENV=development                  # development | staging | production
DEBUG=true
LOG_LEVEL=INFO
TZ=Europe/Moscow

# --- Backend / API -----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_PUBLIC_URL=http://localhost:8000     # used in Callback API URL generation
FRONTEND_URL=http://localhost:5173

# --- Security ----------------------------------------------------------------
JWT_SECRET=change-me-to-a-32-byte-random-string
JWT_ACCESS_TTL_SECONDS=3600              # 1 hour
JWT_REFRESH_TTL_SECONDS=2592000          # 30 days
# AES-256 key for encrypting VK community access tokens (base64, 32 bytes)
TOKEN_ENCRYPTION_KEY=change-me-base64-encoded-32-bytes

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=vk_saas
POSTGRES_PASSWORD=vk_saas_dev_password
POSTGRES_DB=vk_saas
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://vk_saas:vk_saas_dev_password@postgres:5432/vk_saas

# --- Redis -------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Qdrant ------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# --- S3 (Yandex Object Storage) ----------------------------------------------
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=vk-saas-media

# --- VK Mini App -------------------------------------------------------------
# Get these from https://vk.com/editapp?act=create
VK_APP_ID=
VK_APP_SECURE_KEY=                       # used to validate launch_params signature
VK_APP_SERVICE_TOKEN=                    # service token for server-side VK API calls

# --- OpenAI (default LLM + embeddings + image gen) ---------------------------
OPENAI_API_KEY=
OPENAI_MODEL_DIALOG=gpt-4o
OPENAI_MODEL_EMBEDDING=text-embedding-3-small
OPENAI_MODEL_IMAGE=gpt-image-2

# --- Anthropic (optional per-agent override) ---------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DIALOG=claude-sonnet-4-6

# --- Outbound HTTP proxy (for OpenAI/Anthropic from RU) ----------------------
# Format: http://user:pass@host:port  OR  socks5://user:pass@host:port
HTTP_PROXY=
HTTPS_PROXY=

# --- ЮKassa (payments) -------------------------------------------------------
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# --- Observability -----------------------------------------------------------
SENTRY_DSN=
PROMETHEUS_ENABLED=true
